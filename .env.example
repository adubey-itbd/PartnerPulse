# PartnerPulse — optional environment overrides.
# Copy to ".env" to override the keys baked into extract/config.py.
# (For a real deployment, set these via a secret manager, not a file.)

# HaloPSA (OAuth2 client_credentials, read-only)
HALO_BASE_URL=https://itbd.halopsa.com
HALO_CLIENT_ID=
HALO_CLIENT_SECRET=
HALO_SCOPE=all

# TeamGPS Open API
TEAMGPS_BASE_URL=https://api.team-gps.net/open-api/v1
TEAMGPS_API_KEY=

# Claude churn analysis (Claude Agent SDK, billed to your Claude subscription).
# No API key: authenticate the `claude` CLI once with `claude setup-token` (or
# `claude login`) on a Pro/Max/Team/Enterprise plan. Do NOT set ANTHROPIC_API_KEY
# — extract/ai.py removes it so spend stays on the subscription, not the API.
# CLAUDE_MODEL overrides the model used for analysis.
CLAUDE_MODEL=claude-sonnet-4-6

# Optional path overrides
# PARTNERPULSE_TRANSCRIPTS=
# PARTNERPULSE_DATA=

# Microsoft Graph app registration (transcript ingestion - see docs/IT-Request-Graph-Transcript-Access.md)
GRAPH_TENANT_ID=d3ce7374-043d-42ad-9d54-b68633f244c9
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
