# PartnerPulse — optional environment overrides.
# Copy to ".env" to override the keys baked into extract/config.py.
# (For a real deployment, set these via a secret manager, not a file.)

# HaloPSA (OAuth2 client_credentials, read-only)
HALO_BASE_URL=https://itbd.halopsa.com
HALO_CLIENT_ID=
HALO_CLIENT_SECRET=
HALO_SCOPE=all

# TeamGPS Open API
TEAMGPS_BASE_URL=https://api.team-gps.net/open-api/v1
TEAMGPS_API_KEY=

# AI churn analysis — Grok via Azure AI Foundry (OpenAI-compatible, synchronous).
# base_url + API key (the OpenAI SDK, not the AzureOpenAI client). Deployment is
# Global Standard `grok-4-1-fast-reasoning` (50k TPM / 50 RPM).
AI_BASE_URL=https://daku.services.ai.azure.com/openai/v1/
AI_API_KEY=
AI_MODEL=grok-4-1-fast-reasoning

# Optional path overrides
# PARTNERPULSE_TRANSCRIPTS=
# PARTNERPULSE_DATA=

# Microsoft Graph app registration (transcript ingestion - see docs/IT-Request-Graph-Transcript-Access.md)
GRAPH_TENANT_ID=d3ce7374-043d-42ad-9d54-b68633f244c9
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
