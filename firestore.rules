rules_version = '2';

// PartnerPulse — ALL dashboard data lives in Firestore (sharded).
//   meta/overview                  portfolio rollups + coverage (Exec Overview)
//   meta/csatRecon                 the CSAT Reconciliation feed  (single doc)
//   meta/cwAgreements              the Renewal Risk feed (CW agreements; single doc)
//   partners/{slug}                per-partner summary doc       (Exec Overview)
//   partners/{slug}/detail/profile client meta + AI + CSAT/NPS stats
//   partners/{slug}/transcripts|decks|calls|sip|csat|nps|actions/{id}
//                                  the detail layer, one doc per item
//
// Reads are restricted to verified @itbd.net accounts (email/password sign-in;
// email_verified proves mailbox ownership). Dashboard *data* client writes are
// denied — the build pipeline writes via the Admin SDK
// (scripts/upload_firebase_data.py), which bypasses these rules. Two narrow
// client-writable exceptions exist, both create/append-only, validated, with no
// client reads (reviewed in the Firebase console): the public `feedback`
// collection (feedback.html, unauthenticated CREATE) and the sign-in audit
// `login_audit` / `login_audit_summary` (auth.js — verified @itbd.net users
// recording only their own sign-ins).
service cloud.firestore {
  match /databases/{database}/documents {

    // SINGLE LOAD-BEARING ACCESS CLAUSE. Every readable match below gates on
    // isItbd() and nothing else — this function is the entire server-side
    // security boundary for the dashboard. All three conditions are required:
    //   (1) request.auth != null            -> signed in at all
    //   (2) email_verified == true          -> proved mailbox ownership (the
    //       client allowlist in auth.js is cosmetic; THIS is enforced)
    //   (3) email in the explicit ALLOWLIST -> named individuals only
    // ACCESS IS NOW A NAMED ALLOWLIST, NOT THE WHOLE @itbd.net DOMAIN (2026-06-22,
    // by request — "only these people, no one else for now"). To add/remove a
    // person, edit BOTH this list AND the ALLOWED_EMAILS array in auth.js, then
    // redeploy rules + hosting. Emails are lowercase (Firebase normalizes tokens).
    // Do NOT weaken or duplicate this logic inline; change it here only, and
    // keep all writes denied (the Admin SDK pipeline bypasses rules entirely).
    function isItbd() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'amit.dubey@itbd.net',
          'vishal.dogra@itbd.net',
          'keith.rozario@itbd.net',
          'andrea.canlas@itbd.net',
          'lee.cavellier@itbd.net',
          'jkhan@itbd.net',
          'manu.sharma@itbd.net'
        ];
    }

    // Public feedback form (feedback.html) — the ONLY client-writable path.
    // Anyone (no sign-in) may CREATE a feedback doc; nobody may read/update/
    // delete it via the client (reviewed in the Firebase console / Admin SDK).
    // Validation below caps size and locks the key set so the open create can't
    // be abused as arbitrary storage. `submitted_at` must be the server time
    // (the form sends FieldValue.serverTimestamp()).
    function isValidFeedback() {
      let d = request.resource.data;
      return d.message is string && d.message.size() >= 1 && d.message.size() <= 5000
        && d.submitted_at == request.time
        && (!('name' in d)       || (d.name is string       && d.name.size() <= 120))
        && (!('email' in d)      || (d.email is string      && d.email.size() <= 200))
        && (!('company' in d)    || (d.company is string    && d.company.size() <= 160))
        && (!('category' in d)   || (d.category is string   && d.category.size() <= 60))
        && (!('rating' in d)     || (d.rating is int        && d.rating >= 1 && d.rating <= 5))
        && (!('page' in d)       || (d.page is string       && d.page.size() <= 300))
        && (!('user_agent' in d) || (d.user_agent is string && d.user_agent.size() <= 500))
        && d.keys().hasOnly(['message', 'category', 'page', 'user_agent',
                             'submitted_at', 'name', 'email', 'company', 'rating']);
    }

    // Portfolio meta.
    match /meta/{doc} {
      allow read: if isItbd();
      allow write: if false;
    }

    // Partner summary + everything under it (detail/profile + all subcollections).
    match /partners/{slug} {
      allow read: if isItbd();
      allow write: if false;

      match /{document=**} {
        allow read: if isItbd();
        allow write: if false;
      }
    }

    // Public feedback (feedback.html). Create-only, validated; no client reads.
    match /feedback/{id} {
      allow create: if isValidFeedback();
      allow read, update, delete: if false;
    }

    // Sign-in audit (auth.js recordLogin). Two client-writable paths, both
    // restricted to verified @itbd.net users writing ONLY their own identity;
    // no client reads (review in the Firebase console). See changelog 2026-06-22.
    //   login_audit/{id}            one immutable doc per sign-in session
    //   login_audit_summary/{uid}   per-user rollup: count + last_login
    match /login_audit/{id} {
      allow create: if isItbd()
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.ts == request.time
        && (!('page' in request.resource.data)
            || (request.resource.data.page is string && request.resource.data.page.size() <= 300))
        && (!('user_agent' in request.resource.data)
            || (request.resource.data.user_agent is string && request.resource.data.user_agent.size() <= 500))
        && request.resource.data.keys().hasOnly(['email', 'uid', 'ts', 'page', 'user_agent']);
      allow read, update, delete: if false;
    }
    match /login_audit_summary/{uid} {
      allow create: if isItbd()
        && uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.count == 1
        && request.resource.data.last_login == request.time
        && request.resource.data.keys().hasOnly(['email', 'count', 'last_login']);
      allow update: if isItbd()
        && uid == request.auth.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.last_login == request.time
        && request.resource.data.keys().hasOnly(['email', 'count', 'last_login']);
      allow read, delete: if false;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
